#!/bin/bash
set -e

if [ -z "$1" ]; then
  echo "Usage: sudo protonpi-set-password 'YourPasswordHere'"
  exit 1
fi

python3 - "$1" <<'PY'
import sys, json, os
from werkzeug.security import generate_password_hash

password = sys.argv[1]
path = "/etc/protonvpn-profiles/dashboard-auth.json"

try:
    data = json.load(open(path))
except Exception:
    data = {}

data["password_hash"] = generate_password_hash(password)
data.setdefault("trusted_devices", {})

with open(path, "w") as f:
    json.dump(data, f, indent=2)

os.chmod(path, 0o600)
print("Dashboard password updated.")
PY

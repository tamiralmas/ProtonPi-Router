#!/bin/bash
ACTION="$1"
IP="$2"

if ! echo "$IP" | grep -Eq '^10\.42\.[0-9]{1,3}\.[0-9]{1,3}$'; then
  echo "Invalid IP"
  exit 1
fi

case "$ACTION" in
  block)
    iptables -C FORWARD -s "$IP" -m comment --comment "PROTONPI_BLOCK_$IP" -j REJECT 2>/dev/null || \
    iptables -I FORWARD 1 -s "$IP" -m comment --comment "PROTONPI_BLOCK_$IP" -j REJECT
    ;;
  unblock)
    while iptables -C FORWARD -s "$IP" -m comment --comment "PROTONPI_BLOCK_$IP" -j REJECT 2>/dev/null; do
      iptables -D FORWARD -s "$IP" -m comment --comment "PROTONPI_BLOCK_$IP" -j REJECT
    done
    ;;
  *)
    echo "Use block|unblock IP"
    exit 1
    ;;
esac
